# このファイルをコピーして「secrets.toml」という名前で保存し、APIキーを設定してください。
# （secrets.toml は .gitignore で除外されています。GitHub等に上がらないので安全）
#
# Streamlit Cloud にデプロイするときは、Cloud側の Secrets 設定画面で同じキーを登録してください。
# https://docs.streamlit.io/streamlit-community-cloud/get-started/deploy-an-app/connect-to-data-sources/secrets-management

ANTHROPIC_API_KEY = "ここにあなたのAPIキーを貼り付け"

# 任意設定（変更不要）
# OCR_MODEL = "claude-opus-4-8"
# OCR_PORT = "8788"
